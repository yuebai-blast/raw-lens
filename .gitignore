/bin/
/dist/
.claude/
.idea/
# Claude Code superpowers 工作目录与文档（spec/计划等），本地保留不入库
.superpowers/
docs/superpowers/

# 实际运行时配置（从 config.example.yaml 复制而来），各环境自有、不入库
config.yaml

# SQLite 抓包数据库（运行时生成，不入库）
*.db
*.db-wal
*.db-shm

# 前端构建产物（由 mise run build 生成），仅保留占位文件
web/dist/*
!web/dist/.keep

# 前端依赖与缓存
frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo
